    <definition id="oval:com.redhat.rhsa:def:20230001" class="patch" version="1">
      <metadata>
        <title>RHSA-2023:0001: openssl security update (Important)</title>
        <affected family="unix">
          <platform>Red Hat Enterprise Linux 8</platform>
        </affected>
        <reference source="RHSA" ref_id="RHSA-2023:0001" ref_url="https://access.redhat.com/errata/RHSA-2023:0001"/>
        <reference source="CVE" ref_id="CVE-2023-1234" ref_url="https://access.redhat.com/security/cve/CVE-2023-1234"/>
        <reference source="CVE" ref_id="CVE-2023-5678" ref_url="https://access.redhat.com/security/cve/CVE-2023-5678"/>
        <description>OpenSSL is a toolkit that implements the Secure Sockets Layer (SSL) and Transport Layer Security (TLS) protocols. This update addresses multiple security vulnerabilities.</description>
        <advisory>
          <severity>Important</severity>
          <rights>Copyright 2023 Red Hat, Inc.</rights>
          <issued date="2023-01-15"/>
          <updated date="2023-01-15"/>
          <cve href="https://access.redhat.com/security/cve/CVE-2023-1234" impact="important">CVE-2023-1234</cve>
          <cve href="https://access.redhat.com/security/cve/CVE-2023-5678" impact="moderate">CVE-2023-5678</cve>
          <bugzilla href="https://bugzilla.redhat.com/1234567" id="1234567">openssl: Remote denial of service vulnerability</bugzilla>
        </advisory>
      </metadata>
      <criteria operator="AND">
        <criterion test_ref="oval:com.redhat.rhsa:tst:20230001001" comment="Red Hat Enterprise Linux 8 is installed"/>
        <criteria operator="OR">
          <criterion test_ref="oval:com.redhat.rhsa:tst:20230001002" comment="openssl is earlier than 1:1.1.1k-7.el8_6"/>
          <criterion test_ref="oval:com.redhat.rhsa:tst:20230001003" comment="openssl-devel is earlier than 1:1.1.1k-7.el8_6"/>
          <criterion test_ref="oval:com.redhat.rhsa:tst:20230001004" comment="openssl-libs is earlier than 1:1.1.1k-7.el8_6"/>
        </criteria>
      </criteria>
    </definition>
    <definition id="oval:com.redhat.rhsa:def:20230002" class="patch" version="1">
      <metadata>
        <title>RHSA-2023:0002: kernel security update (Critical)</title>
        <affected family="unix">
          <platform>Red Hat Enterprise Linux 8</platform>
          <platform>Red Hat Enterprise Linux 9</platform>
        </affected>
        <reference source="RHSA" ref_id="RHSA-2023:0002" ref_url="https://access.redhat.com/errata/RHSA-2023:0002"/>
        <reference source="CVE" ref_id="CVE-2023-9999" ref_url="https://access.redhat.com/security/cve/CVE-2023-9999"/>
        <description>The kernel packages contain the Linux kernel, the core of any Linux operating system. This update addresses a critical privilege escalation vulnerability.</description>
        <advisory>
          <severity>Critical</severity>
          <rights>Copyright 2023 Red Hat, Inc.</rights>
          <issued date="2023-01-20"/>
          <updated date="2023-01-20"/>
          <cve href="https://access.redhat.com/security/cve/CVE-2023-9999" impact="critical">CVE-2023-9999</cve>
        </advisory>
      </metadata>
      <criteria operator="AND">
        <criteria operator="OR">
          <criterion test_ref="oval:com.redhat.rhsa:tst:20230002001" comment="Red Hat Enterprise Linux 8 is installed"/>
          <criterion test_ref="oval:com.redhat.rhsa:tst:20230002002" comment="Red Hat Enterprise Linux 9 is installed"/>
        </criteria>
        <criterion test_ref="oval:com.redhat.rhsa:tst:20230002003" comment="kernel is earlier than 0:4.18.0-425.10.1.el8_7"/>
      </criteria>
    </definition>
